# AgentMesh Backend - Environment Variables
# Copy to .env and fill in values

# Server
SERVER_PORT=8080

# PostgreSQL (shared dev-postgres on port 5435 per ~/infra/onboarding.md)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5435/agentmesh
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Redis (shared dev-redis on port 6381 per ~/infra/onboarding.md)
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6381

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Auto-BADS integration
AUTOBADS_BASE_URL=http://localhost:8083

# LLM Provider: "openai-compatible" | "ollama" | (empty = MockLLM)
LLM_PROVIDER=openai-compatible

# LMStudio (primary local inference, per Architect Protocol v7.8)
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=
LLM_MODEL=default
LLM_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Ollama (alternative local, native API)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (cloud, set API key)
OPENAI_API_KEY=

# GitHub Integration (optional)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Security (production)
API_KEY_AUTH_ENABLED=false
AGENTMESH_API_KEY=

# PII Encryption (AES-256-GCM) — generate with: openssl rand -base64 32
# Leave empty for passthrough mode (no encryption)
PII_ENCRYPTION_KEY=

# Weaviate
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8079

