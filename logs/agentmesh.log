2026-04-19 14:05:23.148 [main] DEBUG o.f.c.i.s.DefaultSqlScriptExecutor [CID:N/A] [Tenant:N/A] [Agent:N/A] - Executing SQL: -- Daily token usage by project
CREATE VIEW v_daily_token_usage AS
SELECT 
    DATE(timestamp) AS usage_date,
    tenant_id,
    project_id,
    model,
    SUM(total_tokens) AS total_tokens,
    SUM(estimated_cost) AS total_cost,
    COUNT(*) AS request_count
FROM token_usage_records
GROUP BY DATE(timestamp), tenant_id, project_id, model
